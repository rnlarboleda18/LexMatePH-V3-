{
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/api/*",
            "/images/*.{png,jpg,gif}",
            "/css/*"
        ]
    },
    "routes": [
        {
            "route": "/api/*",
            "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
            "allowedRoles": ["anonymous", "authenticated"]
        }
    ],
    "platform": {
        "apiRuntime": "python:3.10"
    }
}
