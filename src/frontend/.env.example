# Copy to .env.local for local overrides. Production uses .env.production (CI secrets).

# Clerk (required)
VITE_CLERK_PUBLISHABLE_KEY=

# When the SPA is served without /api on the same host (e.g. Vite dev without proxy), set the Functions base URL:
# VITE_API_BASE_URL=http://127.0.0.1:7071

# Optional: Meta Page Plugin — some browsers/regions need a real app ID for the Facebook embed on Updates.
# VITE_FACEBOOK_APP_ID=
