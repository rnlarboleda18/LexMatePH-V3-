# Copy to .env.local for local overrides (recommended). Do not commit .env.local or .env.production.

# Optional: HTTPS for Vite dev (set in .env.development.local). Use when testing iPhone "Add to Home Screen"
# standalone mode — open https://<your-LAN-IP>:5173, trust the dev certificate once, then Add to Home Screen.
# LEXMATE_HTTPS=1

# Clerk (required for local dev)
VITE_CLERK_PUBLISHABLE_KEY=

# When the SPA is served without /api on the same host (e.g. Vite dev without proxy), set the Functions base URL:
# VITE_API_BASE_URL=http://127.0.0.1:7071

# Optional: Meta Page Plugin — some browsers/regions need a real app ID for the Facebook embed on Updates.
# VITE_FACEBOOK_APP_ID=
